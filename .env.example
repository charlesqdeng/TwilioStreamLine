# StreamLine Backend Environment Variables
# Copy this file to backend/.env and fill in your values

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/streamline

# For production, use connection pooling:
# DATABASE_URL=postgresql://user:password@host:5432/streamline?pool_timeout=10&connect_timeout=10&sslmode=require

# ============================================
# Redis Configuration
# ============================================
REDIS_URL=redis://localhost:6379

# For production with password:
# REDIS_URL=redis://:password@host:6379

# ============================================
# Encryption & Security
# ============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_ENCRYPTION_KEY=your_64_character_hex_string_here

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ============================================
# Server Configuration
# ============================================
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Backend URL (for OAuth callbacks)
BACKEND_URL=http://localhost:3001

# ============================================
# Webhook Configuration
# ============================================
# For development with ngrok:
# WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok.io/v1/ingest

# For production:
# WEBHOOK_BASE_URL=https://api.streamline.yourdomain.com/v1/ingest
WEBHOOK_BASE_URL=https://api.streamline.app/v1/ingest

# ============================================
# App Configuration
# ============================================
MAX_EVENTS_PER_SUBACCOUNT=1000

# ============================================
# Optional: Twilio OAuth (Phase 5 - Future)
# ============================================
# TWILIO_OAUTH_CLIENT_ID=your-client-id
# TWILIO_OAUTH_CLIENT_SECRET=your-client-secret

# ============================================
# Google OAuth (Optional - for "Sign in with Google")
# ============================================
# Get credentials from: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# Notification Configuration
# ============================================
# Email Configuration (choose 'smtp' or 'sendgrid')
EMAIL_PROVIDER=smtp
EMAIL_FROM=StreamLine <noreply@streamline.app>

# SMTP Configuration (for Gmail, Outlook, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# SendGrid Configuration (alternative to SMTP)
# SENDGRID_API_KEY=your-sendgrid-api-key

# Twilio SMS Configuration (separate from subaccount credentials)
# These are used for sending SMS notifications
TWILIO_NOTIFICATION_ACCOUNT_SID=your-twilio-account-sid
TWILIO_NOTIFICATION_AUTH_TOKEN=your-twilio-auth-token
TWILIO_NOTIFICATION_FROM_PHONE=+1234567890

# Daily Summary Cron Schedule (UTC timezone)
# Format: minute hour day month day-of-week
# Default: 9 AM UTC every day
DAILY_SUMMARY_CRON=0 9 * * *

# ============================================
# Optional: Monitoring & Error Tracking
# ============================================
# SENTRY_DSN=your-sentry-dsn-here
# LOG_LEVEL=info
